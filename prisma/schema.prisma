generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id         Int       @id @default(autoincrement())
  workguruId String    @unique
  name       String
  projects   Project[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model DisplayStage {
  id        Int            @id @default(autoincrement())
  name      String         @unique
  order     Int
  color     String
  mappings  StageMapping[]
  projects  Project[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model StageMapping {
  id             Int          @id @default(autoincrement())
  workguruStatus String       @unique
  displayStageId Int
  displayStage   DisplayStage @relation(fields: [displayStageId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Project {
  id                 Int           @id @default(autoincrement())
  workguruId         String        @unique
  projectNumber      String
  name               String
  clientId           Int
  client             Client        @relation(fields: [clientId], references: [id])
  displayStageId     Int?
  displayStage       DisplayStage? @relation(fields: [displayStageId], references: [id])
  rawStatus          String
  budgetHours        Float         @default(0)
  actualHours        Float         @default(0)
  remainingHours     Float         @default(0)
  progressPercent    Float         @default(0)
  deliveryDate       DateTime?
  drawingStatus      String?       // Not Started / Sent / Approved
  procurementStatus  String?       // Ordered / Received
  productionReadiness String?
  tasks              Task[]
  timeEntries        TimeEntry[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([clientId])
  @@index([displayStageId])
}

model Task {
  id          Int         @id @default(autoincrement())
  workguruId  String      @unique
  projectId   Int
  project     Project     @relation(fields: [projectId], references: [id])
  name        String
  budgetHours Float       @default(0)
  actualHours Float       @default(0)
  timeEntries TimeEntry[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([projectId])
}

model TimeEntry {
  id         Int      @id @default(autoincrement())
  workguruId String   @unique
  projectId  Int
  project    Project  @relation(fields: [projectId], references: [id])
  taskId     Int?
  task       Task?    @relation(fields: [taskId], references: [id])
  hours      Float
  date       DateTime
  user       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
  @@index([taskId])
}

model SystemConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SyncLog {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  status    String   // SUCCESS / FAILURE / MISMATCH
  details   String?  @db.Text
}
